# Chain: 84532 = Base Sepolia, 8453 = Base mainnet
NEXT_PUBLIC_CHAIN_ID=84532

# WeteEgoGateway address (from WeteEgo-Contracts deploy)
NEXT_PUBLIC_GATEWAY_ADDRESS=0x...

# RPC URL for the chain
NEXT_PUBLIC_RPC_URL=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Backend API base URL (required for Convert)
NEXT_PUBLIC_API_URL=http://localhost:3001

# WalletConnect project ID (optional)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=
